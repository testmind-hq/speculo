# E2E test environment configuration
# Copy to .env.e2e and fill in values, or export as environment variables in CI.
# Never commit .env.e2e to git.

# Target URL of the deployed Speculo instance
BASE_URL=http://localhost:3000

# Admin account credentials (must match ADMIN_PASSWORD used when starting the server)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_min8chars

# Password for the ephemeral regular user created during e2e tests
E2E_USER_PASSWORD=Test@12345
