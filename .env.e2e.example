# E2E test environment configuration
# Copy to .env.e2e and fill in values, or export as env vars before running tests.
# Never commit .env.e2e (it is already gitignored).

# Target URL of the Speculo instance under test
# Local dev (Vite):       http://localhost:5173
# Local prod (Docker):    http://localhost:3000
# Remote instance:        http://your-server:3000
BASE_URL=http://localhost:3000

# Admin account — must match the ADMIN_PASSWORD used when the server was started
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_min8chars

# Ephemeral test user created by the e2e setup (safe to re-use across runs)
TEST_USER_EMAIL=e2e-user@speculo.test
TEST_USER_PASSWORD=e2e-test-password-123
